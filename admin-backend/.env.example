APP_NAME=饭否后台
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=zh_CN
APP_FAKER_LOCALE=zh_CN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=what_to_eat_admin
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# 微信登录（真实登录必填）：与当前小程序 AppID 一致，Secret 在公众平台「开发管理 → 开发设置」
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 开发兜底（可选）：设为 true 时不请求微信服务器，仅本地联调。真实登录不要配置或设为 false。
# WECHAT_DEV_BYPASS=false
# WECHAT_DEV_FORCE_USER_ID=2
# 若曾执行 config:cache，微信相关变量已写入缓存；改 .env 后请 php artisan config:clear 或 config:cache

# 可选：首次超级管理员（php artisan db:seed --class=BootstrapSuperAdminSeeder）
# ADMIN_BOOTSTRAP_EMAIL=admin@example.com
# ADMIN_BOOTSTRAP_PASSWORD=your-secure-password
# ADMIN_BOOTSTRAP_NAME=超级管理员

# 内部服务 / 运维脚本调用 Laravel 内部路由时使用的鉴权头（如模型中心运行时配置）
# 请设置一个随机长字符串；仅服务器侧配置，勿写入小程序包
INTERNAL_SERVICE_TOKEN=

# 今日推荐：天气上下文（wttr.in，可关闭或改城市）
# RECOMMENDATION_WEATHER_ENABLED=true
# RECOMMENDATION_WEATHER_CITY=Beijing
# RECOMMENDATION_WEATHER_TIMEOUT=3
