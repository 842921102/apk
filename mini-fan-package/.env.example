# 与 Web 项目相同的 Supabase 项目（anon key，勿提交 service_role）
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# Laravel API 根地址、静态配置 JSON 已迁移至 config/env/（见 README_ENV.md）
# 请勿再依赖下方两项驱动业务；保留为空即可。
# ---------------------------------------------------------------------------
# VITE_API_BASE_URL=
# VITE_APP_CONFIG_URL=

# 本地开发：在 admin-backend 执行 `php artisan serve`（默认 http://127.0.0.1:8000），
# 并在 mini-fan-package/config/env/dev.ts 中将 baseUrl 指向同一地址。
# 真机预览请使用电脑局域网 IP，并在微信开发者工具勾选不校验合法域名。
