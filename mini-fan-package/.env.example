# 与 Web 项目相同的 Supabase 项目（anon key，勿提交 service_role）
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# BFF / API 根地址、静态配置 JSON 已迁移至 config/env/（见 README_ENV.md）
# 请勿再依赖下方两项驱动业务；保留为空即可。
# ---------------------------------------------------------------------------
# VITE_API_BASE_URL=
# VITE_APP_CONFIG_URL=

# 以下为历史说明，供参考：
#
# 启动 BFF：在仓库 bff-server 目录执行 npm start；mini-fan-package 下可：npm run bff:start
#
# 微信开发者工具模拟器可用 http://localhost:端口；真机预览时请使用电脑局域网 IP，
# 并在「详情 → 本地设置」勾选不校验合法域名。
#
# 域名与端口请在 config/env/dev.ts 等处修改，与 bff-server 的 PORT 一致（默认 8787）。
