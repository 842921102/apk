# BFF 监听端口
PORT=8787

# 监听网卡：真机连局域网 IP 须 0.0.0.0（默认已是 0.0.0.0，仅本机可显式写 127.0.0.1）
HOST=0.0.0.0

# 大模型（智谱/GLM）
BIGMODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4
BIGMODEL_API_KEY=your_text_api_key_here
BIGMODEL_MODEL=glm-4-flash

# Supabase（用于云端图鉴等数据读取；需配置 RLS 已开）
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# （可选）当你希望 BFF 校验用户时，可以把 access_token 校验逻辑放在这里
# CURRENTLY: today-eat 最小实现不会强制 401，避免影响体验版

# Laravel admin-backend 基础地址（给微信登录用）
# 例如：http://localhost:8000
ADMIN_BACKEND_BASE_URL=

