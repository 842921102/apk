# BFF 监听端口（默认 8787；与小程序 mini-fan-package/.env 的 VITE_API_BASE_URL 端口一致即可）
PORT=8787

# 监听网卡：真机连局域网 IP 须 0.0.0.0（默认已是 0.0.0.0，仅本机可显式写 127.0.0.1）
HOST=0.0.0.0

# 模型中心读取依赖（从 admin-backend 的“模型中心”按 scene 拉取）
# 例如：http://127.0.0.1:8000（与 `php artisan serve` 默认一致）
# 留空时：仅当 NODE_ENV 不是 production 时默认 http://127.0.0.1:8000；生产部署务必显式填写
ADMIN_BACKEND_BASE_URL=

# 与 admin-backend/.env 的 INTERNAL_SERVICE_TOKEN 保持一致
INTERNAL_SERVICE_TOKEN=

# Supabase（用于云端图鉴等数据读取；需配置 RLS 已开）
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# （可选）当你希望 BFF 校验用户时，可以把 access_token 校验逻辑放在这里
# CURRENTLY: today-eat 最小实现不会强制 401，避免影响体验版

# 说明：
# - 微信登录、收藏/历史代理、AI 场景配置都走 ADMIN_BACKEND_BASE_URL
# - BFF 不再直接持有 BIGMODEL_* 配置
#
# 排障（小程序 POST /api/auth/wechat 出现 502）：
# A) 浏览器打开 http://<本机IP>:<PORT>/health/deps 若出现 Chrome「无法处理此请求」类 502 HTML 页：
#    本仓库 Node 对 /health/deps 始终返回 200 + JSON，不会是空 502。说明请求没到 Node：请先在本目录执行 npm start；
#    或你前面有 Nginx 占用了 <PORT>，需启动 Nginx 的 upstream（Node）或改 PORT / 反代配置。
# B) 若 /health/deps 能打开且为 JSON，但 admin_backend.up_ok 为 false：
# 1) 先在本机启动 Laravel：cd admin-backend && php artisan serve（默认 http://127.0.0.1:8000）
# 2) 确认本项 ADMIN_BACKEND_BASE_URL 与上一步端口一致（不要多写 /api）
# 3) BFF 若在 Docker 内，勿用 127.0.0.1 指宿主机 Laravel，改用 host.docker.internal 或宿主机局域网 IP

