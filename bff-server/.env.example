# BFF 监听端口
PORT=8787

# 监听网卡：真机连局域网 IP 须 0.0.0.0（默认已是 0.0.0.0，仅本机可显式写 127.0.0.1）
HOST=0.0.0.0

# 模型中心读取依赖（从 admin-backend 的“模型中心”按 scene 拉取）
# 例如：http://localhost:8000
ADMIN_BACKEND_BASE_URL=

# 与 admin-backend/.env 的 INTERNAL_SERVICE_TOKEN 保持一致
INTERNAL_SERVICE_TOKEN=

# Supabase（用于云端图鉴等数据读取；需配置 RLS 已开）
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# （可选）当你希望 BFF 校验用户时，可以把 access_token 校验逻辑放在这里
# CURRENTLY: today-eat 最小实现不会强制 401，避免影响体验版

# 说明：
# - 微信登录、收藏/历史代理、AI 场景配置都走 ADMIN_BACKEND_BASE_URL
# - BFF 不再直接持有 BIGMODEL_* 配置
#
# 排障（小程序 POST /api/auth/wechat 出现 502）：
# 1) 先在本机启动 Laravel：cd admin-backend && php artisan serve（默认 http://127.0.0.1:8000）
# 2) 确认本项 ADMIN_BACKEND_BASE_URL 与上一步端口一致（不要多写 /api）
# 3) 浏览器或 curl 访问：http://127.0.0.1:<BFF端口>/health/deps
#    看 admin_backend.up_ok 是否为 true；若为 false，说明从 BFF 进程连不上 Laravel（Docker 内勿用 127.0.0.1，改用 host.docker.internal）

